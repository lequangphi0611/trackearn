DATABASE_URL=postgresql://trackearn:trackearn@localhost:5432/trackearn
BETTER_AUTH_SECRET=change-me-in-production
BETTER_AUTH_URL=http://localhost:3000

# Logging (tùy chọn — xem docs/rules/logging.md)
# LOG_LEVEL=debug      # mặc định: debug (dev) / info (prod)
# SLOW_QUERY_MS=200    # ngưỡng (ms) cảnh báo query chậm ở prod

# Trang chẩn đoán DEV /admin (HTTP Basic Auth, tách Better Auth). BẮT BUỘC ở
# prod — thiếu thì /admin trả 401 cứng. Đặt mật khẩu mạnh, riêng dev giữ.
ADMIN_USER=admin
ADMIN_PASS=change-me
